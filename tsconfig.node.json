{
  "extends": "@tsconfig/node-lts/tsconfig.json",
  "include": [
    "cypress.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
    "rslib.config.*",
    "rslint.config.*",
    "rstest.config.*"
  ],
  "compilerOptions": {
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  }
}
